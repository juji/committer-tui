{
  "name": "committer-tui",
  "version": "0.5.0",
  "module": "src/index.tsx",
  "type": "module",
  "license": "MIT",
  "description": "Committer CLI - AI-assisted git commit TUI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juji/committer-tui.git"
  },
  "bin": {
    "committer": "bin/committer.mjs"
  },
  "files": [
    "bin"
  ],
  "scripts": {
    "dev": "__LOCALOG_ENABLED=\"1\" bun run --watch src/index.tsx",
    "dev:test": "bun run src/index.tsx",
    "dev:rmconf": "rm -rf ~/.config/committer && rm -rf ~/.cache/committer",
    "random-text": "bun run scripts/random-text.ts",
    "localog": "localog",
    "postinstall": "node bin/postinstall.mjs"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@ai-sdk/anthropic": "^4.0.7",
    "@ai-sdk/google": "^4.0.3",
    "@ai-sdk/openai": "^4.0.4",
    "@opentui/core": "^0.4.2",
    "@opentui/react": "^0.4.2",
    "ai": "^7.0.8",
    "localog": "^1.0.3",
    "ollama-ai-provider": "^1.2.0",
    "react": "^19.2.6",
    "zod": "4",
    "zustand": "^5.0.14"
  }
}